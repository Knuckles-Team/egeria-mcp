# ==============================================================================
# Egeria MCP — Environment Configuration
# ==============================================================================
# Sections are split REQUIRED (needed to run the server + reach Egeria) and
# OPTIONAL (only read when you run a specific bottom-up harvest connector). Every
# connector degrades to "skipped" when its credentials are blank, so the OPTIONAL
# vars below are safe to leave empty — they are listed so the full surface is
# tracked. Copy this file to `.env` and fill in what you use.
# ==============================================================================

# ------------------------------------------------------------------------------
# REQUIRED — MCP server runtime
# ------------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
TRANSPORT=stdio                       # stdio | streamable-http | sse
AUTH_TYPE=none                        # none | oauth | oidc (agent-utilities auth)

# ------------------------------------------------------------------------------
# REQUIRED — Apache Egeria platform / View Server (OMVS)
# ------------------------------------------------------------------------------
EGERIA_PLATFORM_URL=https://egeria.example.invalid:9443
EGERIA_VIEW_SERVER=qs-view-server
EGERIA_USER=
EGERIA_USER_PASSWORD=
EGERIA_TLS_PROFILE=                    # named AgentConfig TLS profile
EGERIA_ENABLE_WRITE=False             # gates every write/harvest tool
EGERIATOOL=True                       # register the Egeria tool set

# ==============================================================================
# OPTIONAL — everything below is only needed for specific features.
# Leave blank to disable; blank connector creds = that harvest is skipped.
# ==============================================================================

# ------------------------------------------------------------------------------
# OPTIONAL — Harvest topology / estate declaration
# ------------------------------------------------------------------------------
EGERIA_HARVEST_TOPOLOGY=              # path to a topology.json override (blank = built-in)
HOST_INVENTORY=                       # path to an Ansible-style hosts inventory
# EGERIA_HARVEST_ENV defaults to ~/.config/agent-utilities/egeria-harvest.env;
# uncomment with an ABSOLUTE path to override (a literal ~ is not expanded here).
# EGERIA_HARVEST_ENV=${XDG_CONFIG_HOME}/agent-utilities/egeria-harvest.env

# ------------------------------------------------------------------------------
# OPTIONAL — OTEL tracing (agent-utilities framework)
# ------------------------------------------------------------------------------
# ENABLE_OTEL=True

# ------------------------------------------------------------------------------
# OPTIONAL — Langfuse / LLMOps harvest connector (egeria_mcp.harvest.llmops)
# ------------------------------------------------------------------------------
LANGFUSE_BASE_URL=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ------------------------------------------------------------------------------
# OPTIONAL — Enterprise Security & Access Governance (Eunomia) — agent-utilities
# ------------------------------------------------------------------------------
# EUNOMIA_TYPE=none                   # none | embedded | remote
# EUNOMIA_POLICY_FILE=mcp_policies.json

# ==============================================================================
# OPTIONAL — Bottom-up harvest connectors (one block per source system)
# ==============================================================================

# --- Ansible Tower / AWX ---
ANSIBLE_TOWER_URL=
ANSIBLE_TOWER_TOKEN=
TOWER_URL=
TOWER_TOKEN=

# --- ArchiveBox ---
ARCHIVEBOX_URL=
ARCHIVEBOX_TOKEN=
ARCHIVEBOX_API_KEY=

# --- ArchiMate model file ---
ARCHI_MODEL_PATH=

# --- RSA Archer (GRC / risk) ---
ARCHER_URL=
ARCHER_TOKEN=
ARCHER_SESSION_ID=                    # alias fallback for ARCHER_TOKEN
ARCHER_APPLICATIONS=risks,controls,findings   # comma-separated app list

# --- Software AG ARIS (enterprise architecture) ---
ARIS_URL=
ARIS_TOKEN=
ARIS_API_TOKEN=                       # alias fallback for ARIS_TOKEN
ARIS_API_PATH=/abs/api/models         # ARIS REST API path

# --- Atlassian (generic agent endpoint) ---
ATLASSIAN_AGENT_URL=
ATLASSIAN_AGENT_TOKEN=
ATLASSIAN_AGENT_USER=

# --- Jira ---
JIRA_URL=
JIRA_TOKEN=
JIRA_USER=

