@prefix fibo-fi: <https://spec.edmcouncil.org/fibo/ontology/FBC/FinancialInstruments/FinancialInstruments/> .
@prefix fibo-org: <https://spec.edmcouncil.org/fibo/ontology/FND/Organizations/Organizations/> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dc: <http://purl.org/dc/terms/> .
@prefix : <http://knuckles.team/kg#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:Endpoint a owl:Class ;
    rdfs:label "Endpoint" ;
    rdfs:comment """An Egeria Endpoint — the network address / connection
    coordinates through which a data resource is reached. Technology-layer
    artifact; may be folded into :DataConnector where endpoint granularity is not
    needed. Egeria: Endpoint. ArchiMate: Technology → CommunicationPath.""" ;
    rdfs:subClassOf :TechnologyLayer .

:GlossaryCategory a owl:Class ;
    rdfs:label "Glossary Category" ;
    rdfs:comment """An Egeria GlossaryCategory — a grouping of glossary terms.
    A thin distinction kept above :Concept so term/category can be told apart in
    SPARQL while glossary terms themselves federate as plain :Concept nodes.
    Egeria: GlossaryCategory. ArchiMate: Strategy → (taxonomy of) Concept.""" ;
    rdfs:subClassOf :Concept .

:confidentialityLevel a owl:DatatypeProperty ;
    rdfs:label "confidentiality level" ;
    rdfs:comment """Confidentiality classification applied to an asset (e.g.
    Unclassified, Internal, Confidential, Restricted). Sourced from an Egeria
    Confidentiality classification; carried as a property so the policy router can
    gate routing on it without a separate node lookup.""" ;
    rdfs:range xsd:string .

:dependsOn a owl:ObjectProperty ;
    rdfs:label "depends on" ;
    rdfs:comment """Structural cross-layer dependency (not data movement): the
    source element relies on the target — a service realizing a store, a store
    hosted on a node, an access policy securing a service, a monitor watching a
    target. Materialized from Egeria DataFlow edges created by the cross-layer
    reconciliation pass (egeria-mcp reconcile, CONCEPT:EG-006), so the KG sees the
    whole estate as one dependency graph alongside :flowsTo lineage.""" .

:derivesFrom a owl:ObjectProperty ;
    rdfs:label "derives from" ;
    rdfs:comment """Data-lineage edge: the target asset is produced/derived by the
    source process. Inverse-style complement of :flowsTo for downstream lineage
    traversal. Egeria: ProcessPort → PortSchema lineage.""" .

:flowsTo a owl:ObjectProperty ;
    rdfs:label "flows to" ;
    rdfs:comment """Data-lineage edge: the source asset (or process port) feeds
    into the target process. Carries Egeria DataFlow / lineage-relationship
    semantics — the unique payload Egeria contributes that the KG does not model
    natively.""" .

:qualifiedName a owl:DatatypeProperty ;
    rdfs:label "qualified name" ;
    rdfs:comment """Egeria's globally-unique qualifiedName for a Referenceable —
    the human-stable identity used to reconcile an Egeria element with the same
    real-world thing catalogued by another source.""" ;
    rdfs:range xsd:string .

:retentionPeriod a owl:DatatypeProperty ;
    rdfs:label "retention period" ;
    rdfs:comment """Retention obligation applied to an asset, from an Egeria
    Retention classification (e.g. an ISO-8601 duration or a named schedule).""" ;
    rdfs:range xsd:string .

<http://knuckles.team/kg/egeria> a owl:Ontology ;
    rdfs:label "Apache Egeria Open Metadata Federation Ontology" ;
    rdfs:comment """Crosswalk that folds Apache Egeria Open Metadata Types into the
    existing ArchiMate-aligned enterprise vocabulary, so Egeria's metadata /
    governance / lineage system-of-record federates with the epistemic-graph KG
    rather than duplicating it.

    Egeria → KG mapping (reuses enterprise/leanix/servicenow classes; only the
    terms with no existing home are defined here):
      Asset/DataStore/Connection -> :DataConnector   GlossaryTerm -> :Concept
      DataSet/Table              -> :DataObject       Process(lineage) -> :ProcessModel
      GovernancePolicy/Rule      -> :Policy           GovernancePrinciple -> :Principle
      GovernanceStrategy         -> :Goal             SoftwareServer/Host -> :Server
      SoftwareServerCapability   -> :Tool             ConnectorType -> :Tool

    Every Egeria-sourced node carries :externalToolId (the Egeria GUID) and a
    domain="egeria" property, which is the federation key for reconciling with
    ServiceNow/ERPNext/Camunda/infra nodes already in the graph. Classifications
    (Confidentiality, Retention, ...) are modelled as node properties plus a
    :governedBy edge to the relevant :Policy — not as nodes.

    CONCEPT:KG-2.9 — self-registering enterprise source extractors.""" ;
    owl:imports <http://knuckles.team/kg/enterprise> .

